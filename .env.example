# AmbsbyMaria Environment Variables
# Copy this file to .env.local for local development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://ambsbymaria.vercel.app
NEXT_PUBLIC_SITE_NAME=AmbsbyMaria

# Database (Prisma/SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Admin Panel (change this to a secure password before deploying)
ADMIN_PASSWORD=your_admin_password_here

# Stripe — Get keys from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Get webhook secret from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Blob (for image uploads) — Get token from: https://vercel.com/dashboard → Storage → Create Blob Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# Meshy AI — Image to 3D model generation — Get API key from: https://app.meshy.ai/settings/api-keys
MESHY_API_KEY=msy_your_api_key_here
